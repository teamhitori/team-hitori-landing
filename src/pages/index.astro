---
import Base from "../layouts/Base.astro";

const B2C_SIGNUP_URL =
  "https://teamhitorib2c.b2clogin.com/teamhitorib2c.onmicrosoft.com/B2C_1_SignUpSignIn_Google/oauth2/v2.0/authorize?client_id=79c882fb-0977-408e-b3b9-5a8128a1e68c&redirect_uri=https://app.teamhitori.com/oauth2/callback&response_type=code&scope=openid%20email%20profile";

const navItems = [
  { label: "Home", href: "#home" },
  { label: "Products", href: "#products" },
  { label: "About", href: "#about" },
  { label: "Contact", href: "#contact" },
];

const features = [
  { icon: "cpu", title: "AI-Powered", description: "Advanced intelligence built-in" },
  { icon: "folder", title: "Project Management", description: "Organize your work efficiently" },
  { icon: "settings", title: "Customizable", description: "Tailor to your workflow" },
  { icon: "globe", title: "Cloud-Based", description: "Access anywhere, anytime" },
  { icon: "code", title: "Developer Tools", description: "Built for developers" },
  { icon: "clock", title: "Real-Time", description: "Instant updates and sync" },
];
---

<Base>
  <!-- Fixed Parallax Background -->
  <div class="fixed inset-0 z-0">
    <div class="absolute inset-0 bg-[#0D0208]"></div>
    <div class="parallax-layer-slow absolute inset-0 opacity-30">
      <div class="absolute inset-0 bg-repeat" style="background-image: url('/matrix-texture.png'); background-size: 100% auto;"></div>
    </div>
    <div class="parallax-layer-fast absolute inset-0 opacity-15">
      <div class="absolute inset-0 bg-repeat" style="background-image: url('/matrix-texture.png'); background-size: 120% auto;"></div>
    </div>
    <div class="absolute inset-0" style="background: radial-gradient(circle at center, transparent 0%, rgba(13, 2, 8, 0.5) 100%);"></div>
    <div class="absolute inset-0 bg-[#00FF41] opacity-[0.02]"></div>
  </div>

  <!-- Scrolling Content -->
  <div class="relative z-10">
    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-[#0D0208]/90 backdrop-blur-lg border-b border-[#00FF41]/20 animate-nav-slide-down shadow-lg shadow-black/40">
      <div class="max-w-7xl mx-auto px-6 py-3">
        <div class="flex items-center justify-between">
          <!-- Logo + Brand -->
          <a href="#home" class="flex items-center gap-3 hover:scale-105 transition-transform">
            <img src="/logo.png" alt="Team Hitori" class="w-10 h-10 rounded-lg" />
            <span class="text-2xl text-[#00FF41]" style="font-family: 'Orbitron', sans-serif;">
              Team Hitori
            </span>
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center gap-8">
            {navItems.map((item) => (
              <a
                href={item.href}
                class="text-gray-300 hover:text-[#00FF41] transition-colors"
              >
                {item.label}
              </a>
            ))}
            <a
              href={B2C_SIGNUP_URL}
              class="px-6 py-2 bg-[#00FF41] text-black rounded-lg hover:bg-[#00CC34] transition-colors"
              style="font-family: 'Orbitron', sans-serif;"
            >
              Get Started
            </a>
          </div>

          <!-- Mobile Menu Button -->
          <button
            id="mobile-menu-btn"
            class="md:hidden text-[#00FF41] p-2"
            aria-label="Toggle menu"
          >
            <svg class="w-6 h-6 menu-open-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg class="w-6 h-6 menu-close-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <!-- Mobile Navigation -->
        <div id="mobile-menu" class="md:hidden hidden mt-4 pb-4 border-t border-[#00FF41]/20 pt-4">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="block py-3 text-gray-300 hover:text-[#00FF41] transition-colors mobile-nav-link"
            >
              {item.label}
            </a>
          ))}
          <a
            href={B2C_SIGNUP_URL}
            class="block w-full mt-4 px-6 py-3 bg-[#00FF41] text-black rounded-lg hover:bg-[#00CC34] transition-colors text-center"
            style="font-family: 'Orbitron', sans-serif;"
          >
            Get Started
          </a>
        </div>
      </div>
    </nav>

    <main>
      <!-- Hero -->
      <section id="home" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
        <div class="relative z-10 max-w-7xl mx-auto px-6 py-20 text-center">
          <div class="flex flex-col items-center gap-8 animate-fade-in-up">
            <!-- Title with Gradient -->
            <h1
              class="text-6xl md:text-8xl lg:text-9xl animate-fade-in-up-delay-1"
              style="font-family: 'Orbitron', sans-serif; background: linear-gradient(135deg, #00FF41 0%, #00CC34 50%, #FFEB3B 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
            >
              Team Hitori
            </h1>

            <!-- Subtitle -->
            <p class="text-xl md:text-2xl text-gray-400 max-w-3xl animate-fade-in-up-delay-2">
              Building the future of SaaS applications
            </p>

            <!-- CTA Button -->
            <a
              href="#products"
              class="mt-8 px-8 py-4 bg-[#00FF41] text-black rounded-lg hover:bg-[#00CC34] transition-all duration-300 shadow-lg shadow-[#00FF41]/30 hover:shadow-[#00FF41]/50 animate-fade-in-up-delay-3"
              style="font-family: 'Orbitron', sans-serif;"
            >
              Explore Our Products
            </a>

          </div>
        </div>

        <!-- Scroll Indicator (outside the flex container so it doesn't overlap) -->
        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-fade-in-delay">
          <div class="w-6 h-10 border-2 border-[#00FF41] rounded-full flex items-start justify-center p-2">
            <div class="w-1 h-2 bg-[#00FF41] rounded-full animate-scroll-bounce"></div>
          </div>
        </div>
      </section>

      <!-- Product Showcase -->
      <section id="products" class="relative py-20 px-6 overflow-hidden">
        <div class="relative z-10 max-w-7xl mx-auto bg-[#0D0208]/80 backdrop-blur-sm rounded-3xl p-8 md:p-12 shadow-[0_0_40px_rgba(0,255,65,0.08),0_20px_60px_rgba(0,0,0,0.5)] border border-[#00FF41]/20">
          <!-- Section Header -->
          <div class="text-center mb-20 reveal">
            <h2
              class="text-5xl md:text-6xl lg:text-7xl text-[#00FF41] mb-6"
              style="font-family: 'Orbitron', sans-serif;"
            >
              Pocket Smyth
            </h2>
            <p class="text-xl text-gray-400 max-w-2xl mx-auto">
              Your intelligent AI assistant for project management and development
            </p>
          </div>

          <!-- Product UI Screenshot -->
          <div class="mb-20 reveal">
            <div class="relative rounded-2xl overflow-hidden border-2 border-[#00FF41]/30 shadow-2xl shadow-[#00FF41]/10">
              <div class="absolute -inset-1 bg-gradient-to-r from-[#00FF41] to-[#008F11] opacity-20 blur-xl"></div>
              <div class="relative bg-[#1A1A1A] p-2">
                <img
                  src="/product-ui.png"
                  alt="Pocket Smyth Interface"
                  class="w-full h-auto rounded-lg"
                />
              </div>
            </div>
          </div>

          <!-- Features Grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {features.map((feature) => (
              <div class="relative group reveal">
                <div class="absolute inset-0 bg-gradient-to-br from-[#00FF41]/10 to-[#008F11]/10 rounded-xl blur-xl group-hover:blur-2xl transition-all duration-300"></div>
                <div class="relative bg-[#1A1A1A] border border-[#00FF41]/20 rounded-xl p-6 hover:border-[#00FF41]/50 hover:scale-105 transition-all duration-300">
                  <div class="text-[#00FF41] mb-4">
                    {feature.icon === "cpu" && (
                      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"></rect><rect x="9" y="9" width="6" height="6"></rect><path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 14h3M1 9h3M1 14h3"></path></svg>
                    )}
                    {feature.icon === "folder" && (
                      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
                    )}
                    {feature.icon === "settings" && (
                      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                    )}
                    {feature.icon === "globe" && (
                      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                    )}
                    {feature.icon === "code" && (
                      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
                    )}
                    {feature.icon === "clock" && (
                      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                    )}
                  </div>
                  <h3
                    class="text-xl mb-2 text-white"
                    style="font-family: 'Orbitron', sans-serif;"
                  >
                    {feature.title}
                  </h3>
                  <p class="text-gray-400">{feature.description}</p>
                </div>
              </div>
            ))}
          </div>

          <!-- CTA Section -->
          <div class="text-center mt-20 reveal">
            <a
              href={B2C_SIGNUP_URL}
              class="inline-block px-10 py-5 bg-transparent border-2 border-[#00FF41] text-[#00FF41] rounded-lg hover:bg-[#00FF41] hover:text-black transition-all duration-300 shadow-lg shadow-[#00FF41]/20 hover:shadow-[#00FF41]/40"
              style="font-family: 'Orbitron', sans-serif;"
            >
              Get Started with Pocket Smyth
            </a>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="relative py-12 px-6">
      <div class="relative z-10 max-w-7xl mx-auto bg-[#0D0208]/80 backdrop-blur-sm rounded-3xl p-8 md:p-12 shadow-[0_0_40px_rgba(0,255,65,0.08),0_20px_60px_rgba(0,0,0,0.5)] border border-[#00FF41]/20">
        <div class="flex flex-col md:flex-row items-center justify-between gap-8">
          <!-- Brand -->
          <div class="reveal">
            <h3
              class="text-2xl text-[#00FF41] mb-2"
              style="font-family: 'Orbitron', sans-serif;"
            >
              Team Hitori
            </h3>
            <p class="text-gray-400">Building the future, one app at a time</p>
          </div>

          <!-- Social Links -->
          <div class="flex gap-4 reveal">
            <a
              href="https://github.com/teamhitori"
              class="w-10 h-10 bg-[#1A1A1A] border border-[#00FF41]/20 rounded-lg flex items-center justify-center text-[#00FF41] hover:border-[#00FF41] hover:bg-[#00FF41]/10 transition-all duration-300 hover:scale-110 hover:-translate-y-0.5"
              aria-label="GitHub"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path></svg>
            </a>
            <a
              href="#"
              class="w-10 h-10 bg-[#1A1A1A] border border-[#00FF41]/20 rounded-lg flex items-center justify-center text-[#00FF41] hover:border-[#00FF41] hover:bg-[#00FF41]/10 transition-all duration-300 hover:scale-110 hover:-translate-y-0.5"
              aria-label="Twitter"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
            </a>
            <a
              href="#"
              class="w-10 h-10 bg-[#1A1A1A] border border-[#00FF41]/20 rounded-lg flex items-center justify-center text-[#00FF41] hover:border-[#00FF41] hover:bg-[#00FF41]/10 transition-all duration-300 hover:scale-110 hover:-translate-y-0.5"
              aria-label="LinkedIn"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            </a>
            <a
              href="mailto:hello@teamhitori.com"
              class="w-10 h-10 bg-[#1A1A1A] border border-[#00FF41]/20 rounded-lg flex items-center justify-center text-[#00FF41] hover:border-[#00FF41] hover:bg-[#00FF41]/10 transition-all duration-300 hover:scale-110 hover:-translate-y-0.5"
              aria-label="Email"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </a>
          </div>
        </div>

        <!-- Bottom Bar -->
        <div class="mt-12 pt-8 border-t border-[#00FF41]/10 text-center text-gray-500">
          <p>&copy; {new Date().getFullYear()} Team Hitori. All rights reserved.</p>
          <p class="mt-2 text-sm">
            <a href="https://teamhitori.com" class="hover:text-[#00FF41] transition-colors">teamhitori.com</a>
          </p>
        </div>
      </div>
    </footer>
  </div>

  <!-- Animations & Interactivity -->
  <style>
    /* Entry Animations */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes navSlideDown {
      from { transform: translateY(-100%); }
      to { transform: translateY(0); }
    }
    @keyframes scrollBounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(10px); }
    }

    .animate-nav-slide-down {
      animation: navSlideDown 0.6s ease-out;
    }
    .animate-fade-in-up {
      animation: fadeInUp 0.8s ease-out both;
    }
    .animate-fade-in-up-delay-1 {
      animation: fadeInUp 0.8s ease-out 0.2s both;
    }
    .animate-fade-in-up-delay-2 {
      animation: fadeInUp 0.8s ease-out 0.4s both;
    }
    .animate-fade-in-up-delay-3 {
      animation: fadeInUp 0.8s ease-out 0.6s both;
    }
    .animate-fade-in-delay {
      animation: fadeInUp 1s ease-out 0.8s both;
    }
    .animate-scroll-bounce {
      animation: scrollBounce 2s ease-in-out infinite;
    }

    /* Scroll-triggered reveal */
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.8s ease-out, transform 0.8s ease-out;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    // Mobile menu toggle
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const openIcon = menuBtn?.querySelector('.menu-open-icon');
    const closeIcon = menuBtn?.querySelector('.menu-close-icon');

    menuBtn?.addEventListener('click', () => {
      const isHidden = mobileMenu?.classList.contains('hidden');
      mobileMenu?.classList.toggle('hidden');
      openIcon?.classList.toggle('hidden');
      closeIcon?.classList.toggle('hidden');
    });

    // Close mobile menu on link click
    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu?.classList.add('hidden');
        openIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
      });
    });

    // Scroll reveal animation
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1 }
    );

    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>
</Base>
